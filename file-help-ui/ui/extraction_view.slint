import { Theme } from "theme.slint";
import { Button, VerticalBox, HorizontalBox, CheckBox, ScrollView, ComboBox, ProgressIndicator } from "std-widgets.slint";

export struct ExtensionToggle {
    ext: string,
    selected: bool,
}

export component SuccessPopup inherits PopupWindow {
    in property <string> message;
    in property <string> error_log: "";
    callback closed;
    
    Rectangle {
        background: Theme.bg_primary;
        border-color: Theme.accent;
        border-width: 1px;
        border-radius: Theme.radius;
        VerticalBox {
            Text { text: root.message; wrap: word-wrap; }
            ScrollView {
                height: 100px;
                Text { 
                    text: root.error_log; 
                    wrap: word-wrap; 
                    font-size: 12px;
                    color: #d93025;
                }
            }
            Button { 
                text: "OK"; 
                clicked => { root.close(); root.closed(); } 
            }
        }
    }
}

export component ExtractionView inherits Rectangle {
    in-out property <int> source_items_count: 0;
    in-out property <string> target_dir;
    in-out property <string> status_message: "Ready";
    in-out property <[ExtensionToggle]> available_extensions;
    in-out property <string> selected_target_format: "raw";
    in-out property <bool> remove_duplicates: false;
    in-out property <float> progress_value: 0.0;
    in-out property <string> status_text: "";
    
    callback add_files();
    callback add_folder();
    callback select_target();
    callback start_extraction();
    callback reset_state();
    callback select_all_extensions();
    callback deselect_all_extensions();

    VerticalBox {
        alignment: start;
        spacing: Theme.padding;
        padding: Theme.padding;

        Text {
            text: "Data Extraction";
            font-size: 24px;
            font-weight: 700;
            color: Theme.text_primary;
        }

        Text {
            text: "Configure extraction directories to begin parsing phase.";
            font-size: 14px;
            color: Theme.text_primary;
        }

        VerticalBox {
            alignment: start;
            HorizontalBox {
                alignment: start;
                Button {
                    text: "Add File(s)";
                    clicked => { root.add_files() }
                }
                Button {
                    text: "Add Folder";
                    clicked => { root.add_folder() }
                }
            }
            Text {
                text: "Items selected: " + root.source_items_count;
                color: Theme.text_primary;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }

        HorizontalBox {
            alignment: start;
            Text {
                text: "Target Format:";
                color: Theme.text_primary;
                vertical-alignment: center;
            }
            ComboBox {
                model: ["raw"];
                current-value: root.selected_target_format;
                selected(val) => { root.selected_target_format = val; }
            }
        }

        HorizontalBox {
            alignment: start;
            Button {
                text: "Select All";
                clicked => { root.select_all_extensions() }
            }
            Button {
                text: "Deselect All";
                clicked => { root.deselect_all_extensions() }
            }
        }

        ScrollView {
            height: 200px;
            VerticalBox {
                alignment: start;
                for item in root.available_extensions: CheckBox {
                    text: item.ext;
                    checked: item.selected;
                    toggled => {
                        item.selected = self.checked;
                    }
                }
            }
        }

        VerticalBox {
            alignment: start;
            Button {
                text: "Select Target";
                clicked => { root.select_target() }
            }
            Text {
                text: "Target Directory: " + (root.target_dir == "" ? "Not Selected" : root.target_dir);
                color: Theme.text_primary;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }

        CheckBox {
            text: "Remove duplicate names/files";
            checked: root.remove_duplicates;
            toggled => { root.remove_duplicates = self.checked; }
        }

        VerticalBox {
            alignment: start;
            Text {
                text: root.status_text;
                color: Theme.text_primary;
            }
            ProgressIndicator {
                progress: root.progress_value;
            }
        }

        Button {
            text: "Start Conversion";
            enabled: root.source_items_count > 0 && root.target_dir != "";
            clicked => { root.start_extraction() }
        }

        Text {
            text: root.status_message;
            color: Theme.text_primary;
            font-size: 14px;
            font-weight: 600;
        }
    }
}
